=================\n# IDEs & editors\n# =============================================================================\n.vscode/\n.idea/\n*.swp\n*.swo\n*~\n.DS_Store\n\n# =============================================================================\n# Logs & databases\n# =============================================================================\n*.log\nlogs/\n*.sqlite\n*.sqlite3\n*.db\n\n# =============================================================================\n# Project-specific\n# =============================================================================\n# Local data cache (Parquet files fetched at runtime)\nlocal_storage/*.parquet\nlocal_storage/metadata.json\n\n# Uploaded files served by FastAPI\nuploads/\n"}
